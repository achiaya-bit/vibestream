# Server
PORT=3001
CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-in-production

# PostgreSQL — use DATABASE_URL or individual DB_* variables
DATABASE_URL=postgresql://vibestream:vibestream@localhost:5432/vibestream
DB_HOST=localhost
DB_PORT=5432
DB_USER=vibestream
DB_PASSWORD=vibestream
DB_NAME=vibestream

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SONGS=songs
MINIO_BUCKET_COVERS=covers
